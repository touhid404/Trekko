// Guide Checkpoint model - Specific physical locations/activities in a guide
model GuideCheckpoint {
    id          String   @id @default(cuid())
    guideId     String
    title       String
    description String?
    order       Int      @default(0)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    // Relations
    guide    TravelGuide               @relation(fields: [guideId], references: [id], onDelete: Cascade)
    progress UserCheckpointProgress[]

    @@index([guideId])
    @@map("guide_checkpoints")
}
