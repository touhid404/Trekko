// Travel Guide model - Main guide content
model TravelGuide {
    id          String      @id @default(cuid())
    memberId    String // FK to Better Auth user
    categoryId  String
    title       String
    description String
    itinerary   Json?
    status      GuideStatus @default(DRAFT)
    isPaid      Boolean     @default(false)
    price       Float?
    coverImage  String?
    isDeleted   Boolean     @default(false)
    deletedAt   DateTime?
    createdAt   DateTime    @default(now())
    updatedAt   DateTime    @updatedAt

    // Relations
    member       User          @relation(fields: [memberId], references: [id], onDelete: Cascade)
    category     Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
    guideMedia   GuideMedia[]
    votes        Vote[]
    comments     Comment[]
    purchases    Purchase[]
    favorites    Favorite[]
    guideReviews GuideReview[]
    checkpoints  GuideCheckpoint[]

    @@index([memberId])
    @@index([categoryId])
    @@map("travel_guides")
}
